{
  "name": "vip-web-frontend",
  "version": "0.0.7",
  "description": "Variant Interpretation Pipeline web interface frontend",
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/molgenis/vip-web/issues"
  },
  "homepage": "https://github.com/molgenis/vip-web#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/molgenis/vip-web.git"
  },
  "scripts": {
    "build": "vite build",
    "build-dev": "vite build --mode dev",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "format": "prettier --write src/**/*.{json,tsx,ts}",
    "lint": "eslint src/**/*.{json,tsx,ts}",
    "prepare": "cd .. && husky vip-web-frontend/.husky",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@creativebulma/bulma-divider": "^1.1.0",
    "@creativebulma/bulma-tagsinput": "^1.0.3",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@solidjs/router": "^0.16.1",
    "axios": "^1.16.1",
    "bulma": "^0.9.4",
    "solid-js": "^1.9.13"
  },
  "lint-staged": {
    "src/**/*.{tsx,ts}": [
      "eslint",
      "prettier --write"
    ]
  }
}
